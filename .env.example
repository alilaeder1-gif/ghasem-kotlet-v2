# توکن ربات تلگرام (از @BotFather بگیرید)
BOT_TOKEN=your_bot_token_here

# کلید API هافینگ‌فیس (از https://huggingface.co/settings/tokens بگیرید)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# مدل هوش مصنوعی
AI_MODEL=meta-llama/Llama-3-8B-Instruct

# مسیر پایگاه داده
DATABASE_PATH=bot_data.db

# پیام خوشامدگویی (اختیاری)
# متغیرها: {name} = نام کاربر، {group} = نام گروه
WELCOME_MESSAGE=سلام {name}! 👋\nبه گروه {group} خوش اومدی!\n\nقوانین گروه رو با /rules بخون.

# تنظیمات اسپم
SPAM_THRESHOLD=5
SPAM_WINDOW=10

# تنظیمات flood
FLOOD_THRESHOLD=3
FLOOD_WINDOW=5

# آیدی ادمین‌ها (اختیاری، با کاما جدا کنید)
# مثال: ADMIN_IDS=123456789,987654321
ADMIN_IDS=
