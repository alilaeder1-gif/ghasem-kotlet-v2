# Bot token
BOT_TOKEN=your_bot_token_here

# DeepSeek API key (get free at https://platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Database path
DATABASE_PATH=bot_data.db

# پیام خوشامدگویی (اختیاری)
# متغیرها: {name} = نام کاربر، {group} = نام گروه
WELCOME_MESSAGE=سلام {name}! 👋\nبه گروه {group} خوش اومدی!\n\nقوانین گروه رو با /rules بخون.

# تنظیمات اسپم
SPAM_THRESHOLD=5
SPAM_WINDOW=10

# تنظیمات flood
FLOOD_THRESHOLD=3
FLOOD_WINDOW=5

# آیدی ادمین‌ها (اختیاری، با کاما جدا کنید)
# مثال: ADMIN_IDS=123456789,987654321
ADMIN_IDS=
